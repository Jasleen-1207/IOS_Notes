protocol FullyNamed {
    var fullName: String {get}
    func sayFullName()
}
struct Person: FullyNamed {
    var firstName: String
    var lastName: String
    var fullName: String {
        return "\(firstName) \(lastName)"
    }
    func sayFullName() {
        print(fullName)
    }
}
