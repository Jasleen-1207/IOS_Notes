//func should be equatable first then comparable
struct Employee: Equatable {
    let firstName: String
    let lastName: String
    let jobTitle: String
    let phoneNumber: String
    static func == (lhs: Employee, rhs: Employee)-> Bool{
        //logic that determines if the value on lhs and rhs are equal
        return lhs.firstName == rhs.firstName && lhs.lastName == rhs.lastName && lhs.jobTitle==rhs.jobTitle && lhs.phoneNumber == rhs.phoneNumber
    }
    static func < (lhs: Employee,rhs: Employee)-> Bool{
        return lhs.firstName < rhs.firstName
    }
}
struct Company{
    let name: String
    let employee: [Employee]
}
